TMDB_API_KEY=your_tmdb_api_key_here
SITE_NAME=DropStream

BRAND_WORDMARK=DROPSTREAM
BRAND_SUBMARK=DROPSTREAM


# Licensed movie provider adapter
# Only set these when you have legal rights / licensed access to the provider.
LICENSED_MOVIE_PROVIDER_ENABLED=false
LICENSED_MOVIE_PROVIDER_API_URL=
LICENSED_MOVIE_PROVIDER_API_KEY=

# Movie button temporary trailer-stream placeholder provider
# Use this for a trailer/preview stream provider now; later swap it to your licensed movie provider.
MOVIE_PLACEHOLDER_PROVIDER_ENABLED=false
MOVIE_PLACEHOLDER_PROVIDER_API_URL=
MOVIE_PLACEHOLDER_PROVIDER_API_KEY=

# Optional param mapping. Defaults match the response/API shape you showed:
MOVIE_PLACEHOLDER_NAME_PARAM=name
MOVIE_PLACEHOLDER_YEAR_PARAM=year
MOVIE_PLACEHOLDER_ID_PARAM=id
MOVIE_PLACEHOLDER_IMDB_PARAM=imdb

# Optional extra query string, for example: turnstile=12
MOVIE_PLACEHOLDER_EXTRA_QUERY=

# Prefer the MP4/ORG stream for the Movie button when the provider returns multiple qualities.
MOVIE_PLACEHOLDER_PREFER_MP4=true
MOVIE_PLACEHOLDER_PREFERRED_QUALITY=ORG


# Try MP4 first, then HLS/AUTO fallback with hls.js when MP4 fails or is missing.
MOVIE_PLACEHOLDER_ALLOW_HLS_FALLBACK=true
